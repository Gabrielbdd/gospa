# Overrides consumed by compose.yaml in this directory.
# Edit any of these before running `docker compose --env-file compose.env up -d`.

# Gospa image tag. Pin to a specific version (e.g. v0.1.0, sha-abc1234)
# by browsing https://github.com/Gabrielbdd/gospa/pkgs/container/gospa
# and replacing the tag below.
GOSPA_IMAGE=ghcr.io/gabrielbdd/gospa:edge

# PostgreSQL image.
POSTGRES_IMAGE=postgres:18.3-alpine3.23

# PostgreSQL credentials. Defaults are insecure — change for anything
# that is not a throwaway evaluation on your own machine.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gospa

# Host port exposed for the Gospa app.
APP_PORT=3000
