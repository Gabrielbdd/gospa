# Optional local overrides for infrastructure and database tasks.
# Copy to `.env` only when you need to change the defaults.

GOFRA_POSTGRES_IMAGE=postgres:18.3-alpine3.23
GOFRA_DB_HOST=localhost
GOFRA_DB_PORT=5432
GOFRA_DB_USER=postgres
GOFRA_DB_PASSWORD=postgres
GOFRA_DB_NAME=gospa
GOFRA_DB_SSLMODE=disable
