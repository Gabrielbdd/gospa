/bin/
/.DS_Store
/.env

# Secrets materialised by `mise run infra`. Only .gitkeep is tracked.
/.secrets/*
!/.secrets/.gitkeep

# Frontend toolchain + codegen. web/.gitignore adds finer-grained
# overrides that keep web/dist/.gitkeep and web/src/gen/.gitkeep tracked
# (so the go:embed all:dist directive compiles before `npm run build`).
/web/node_modules/
